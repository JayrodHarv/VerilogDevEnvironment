{
  "name": "Verilog Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env=WAYLAND_DISPLAY",
    "--env=XDG_RUNTIME_DIR",
    "--volume=${env:XDG_RUNTIME_DIR}:${env:XDG_RUNTIME_DIR}"
  ],
  "containerEnv": {
    "GDK_BACKEND": "wayland"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mshr-h.veriloghdl",
        "chipsalliance.verible",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "verilog.linting.enabled": true,
        "verilog.linting.linter": "verilator",
        "verible.formatting.enabled": true,
        "verible.languageServer.enabled": true
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],
  "workspaceFolder": "/workspace",
  "postCreateCommand": "chmod +x /workspace/scripts/*.sh",
  "remoteUser": "vscode"
}